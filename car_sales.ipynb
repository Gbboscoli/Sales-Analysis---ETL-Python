    {
      "cell_type": "code",
      "source": [
        "# Limpeza da entidade Clientes"
      ],
      "metadata": {
        "id": "IhnztU72kCB0"
      },
      "execution_count": 21,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# remover duplicados\n",
        "clientes = clientes.drop_duplicates()\n",
        "\n",
        "# tratar nome nulo\n",
        "clientes['nome'] = clientes['nome'].fillna('Desconhecido')\n",
        "\n",
        "# idade inválida (menor que 0 ou muito alta)\n",
        "clientes.loc[(clientes['idade'] <= 0) | (clientes['idade'] > 100), 'idade'] = np.nan\n",
        "\n",
        "# preencher idade com média\n",
        "clientes['idade'] = clientes['idade'].fillna(clientes['idade'].mean())\n",
        "\n",
        "# cidade nula\n",
        "clientes['cidade'] = clientes['cidade'].fillna('Não informado')"
      ],
      "metadata": {
        "id": "ol72W58UkMBG"
      },
      "execution_count": 22,
      "outputs": []
    },
