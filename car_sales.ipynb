        "    print(\"\\nNULOS:\")\n",
        "    print(df.isnull().sum())\n",
        "    print(\"\\nDESCRITIVO:\")\n",
        "    print(df.describe(include='all'))\n",
        "\n",
        "diagnostico(clientes, \"CLIENTES\")\n",
        "diagnostico(produtos, \"PRODUTOS\")\n",
        "diagnostico(vendedores, \"VENDEDORES\")\n",
        "diagnostico(vendas, \"VENDAS\")\n",
