    {
      "cell_type": "code",
      "source": [
        "# Preparação dos dados\n",
        "\n",
        "from sklearn.linear_model import LinearRegression\n",
        "import numpy as np\n",
        "\n",
        "# garantir data válida\n",
        "df_final = df_final.dropna(subset=['data'])\n",
        "\n",
        "# agregar por data\n",
        "df_tempo = df_final.groupby('data')['valor_total'].sum().reset_index()\n",
        "\n",
        "# transformar data em número (dias)\n",
        "df_tempo['dias'] = (df_tempo['data'] - df_tempo['data'].min()).dt.days"
      ],
      "metadata": {
        "id": "3o0jjJx1ugsa"
      },
      "execution_count": 58,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Modelo de Regressão\n",
        "\n",
        "X = df_tempo[['dias']]\n",
        "y = df_tempo['valor_total']\n",
        "\n",
        "modelo = LinearRegression()\n",
        "modelo.fit(X, y)\n",
        "\n",
        "# previsão futura (ex: próximos 30 dias)\n",
        "dias_futuros = np.arange(X['dias'].max()+1, X['dias'].max()+31).reshape(-1,1)\n",
        "previsao = modelo.predict(dias_futuros)\n",
        "\n",
        "print(previsao[:5])"
